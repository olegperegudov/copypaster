{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CopyPaster",
  "version": "0.1.28",
  "identifier": "com.copypaster.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CopyPaster",
        "width": 1280,
        "height": 460,
        "resizable": false,
        "center": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "shadow": false
      },
      {
        "label": "shortcuts",
        "title": "Shortcuts",
        "url": "shortcuts.html",
        "width": 420,
        "height": 510,
        "resizable": false,
        "center": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "Settings",
        "url": "settings.html",
        "width": 420,
        "height": 430,
        "resizable": false,
        "center": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-src 'none'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU0MDZEMkI5NUE4M0M0REQKUldUZHhJTmF1ZElHNVBYZUVLa3VpTkdLNDg2VXRCRnV2MTJZNjBjejUyNSszQy90c2U0cUpIUHkK",
      "endpoints": [
        "https://github.com/olegperegudov/copypaster/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": [
      "nsis",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}